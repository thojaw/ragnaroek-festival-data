   "translations":[
      {
         "lang":"de",
         "artists":[
            {
               "id":"a1",
               "description":"Donnerndes norwegisches Folk-Metal-Quartett, das Sagenpoesie und Schlachtzug-Trommelrhythmen vereint. Ihre Live-Shows enden mit einem Chor aus Hornrufen."
            },
            {
               "id":"a2",
               "description":"Atmosphärisches Black-Metal-Duo von den Färöer-Inseln. Eisige Gitarren und klarer Baritongesang über langsamen, bedächtigen Rhythmen."
            },
            {
               "id":"a3",
               "description":"Isländischer Post-Rock mit runenbasierten Songtiteln und einer Vorliebe für neunminütige Crescendos."
            },
            {
               "id":"a4",
               "description":"Sechsköpfiges Pagan-Folk-Ensemble. Nyckelharpa, Rahmentrommeln, Obertongesang und eine Bühne rund um einen Schmiedeamboss."
            },
            {
               "id":"a5",
               "description":"Power-Trio mit donnerschwangerem Stoner Rock. Riffs, breit genug, um ein Langschiff über einen trockenen Strand zu ziehen."
            },
            {
               "id":"a6",
               "description":"Crossover-Thrash aus Göteborg mit Hardcore-Breakdowns und einem Frontmann, der den Pit barfuß umkreist."
            },
            {
               "id":"a7",
               "description":"Akustische Geschichtenerzähler mit skaldischen Versen. Zwei Stimmen, Lyra, Knochenflöte – keine Verstärkung außer einem einzelnen Bändchenmikrofon."
            },
            {
               "id":"a8",
               "description":"Rein weibliches symphonisches Metal-Sextett. Chorgesang, zwei Gitarren, Harfe und eine Bühnenshow mit Speertanz."
            },
            {
               "id":"a9",
               "description":"Erdtöniger Doom aus dem Schwarzwald. Gletscherlangsam, orgelbetrieben und am besten bei Sonnenuntergang zu hören."
            },
            {
               "id":"a10",
               "description":"Sea-Shanty-Hardcore mit Mandoline und Trompete. Der Headliner, für den alle den Merchandise-Stand verlassen."
            }
         ],
