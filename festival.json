   "artists":[
      {
         "id":"a1",
         "name":"Berserkr",
         "imageUrl":"https://metalrun.de/rf/10.png",
         "description":"Thunderous Norwegian folk-metal quartet drawing on saga poetry and battle-march drum patterns. Their live shows close with a wall of horn calls."
      },
      {
         "id":"a2",
         "name":"Bjornholm",
         "imageUrl":"https://metalrun.de/rf/09.png",
         "description":"Atmospheric black-metal duo from the Faroe Islands. Glacial guitars and clean baritone vocals over slow, deliberate rhythms."
      },
      {
         "id":"a3",
         "name":"Drekka Sjór",
         "imageUrl":"https://metalrun.de/rf/08.png",
         "description":"Icelandic post-rock with rune-based song titles and an obsession for nine-minute crescendos."
      },
      {
         "id":"a4",
         "name":"Frost Giants",
         "imageUrl":"https://metalrun.de/rf/07.png",
         "description":"Six-piece pagan-folk ensemble. Nyckelharpa, frame drums, throat-singing and a stage built around a forge anvil."
      },
      {
         "id":"a5",
         "name":"Mjölnir Mark",
         "imageUrl":"https://metalrun.de/rf/06.png",
         "description":"Power-trio playing thunder-soaked stoner rock. Riffs broad enough to drag a longship across a dry beach."
      },
      {
         "id":"a6",
         "name":"Ragnar's Wrath",
         "imageUrl":"https://metalrun.de/rf/05.png",
         "description":"Crossover thrash from Gothenburg with hardcore breakdowns and a frontman who circles the pit barefoot."
      },
      {
         "id":"a7",
         "name":"Skalds of Asgard",
         "imageUrl":"https://metalrun.de/rf/04.png",
         "description":"Acoustic story-singers performing skaldic verse. Two voices, lyre, bone flute, no amplification beyond a single ribbon mic."
      },
      {
         "id":"a8",
         "name":"Valkyrjar",
         "imageUrl":"https://metalrun.de/rf/03.png",
         "description":"All-female symphonic metal sextet. Choral vocals, twin guitars, harp, and a stage show punctuated by spear-dancing."
      },
      {
         "id":"a9",
         "name":"Yggdrasil's Roots",
         "imageUrl":"https://metalrun.de/rf/02.png",
         "description":"Earth-toned doom from the Black Forest. Glacially slow, organ-driven, and best heard at sunset."
      },
      {
         "id":"a10",
         "name":"Black Sails",
         "imageUrl":"https://metalrun.de/rf/01.png",
         "description":"Sea-shanty hardcore with mandolin and trumpet. The headliner everyone leaves the merch tent for."
      }
   ],
